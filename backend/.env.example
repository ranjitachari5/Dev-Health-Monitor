# Dev Health Monitor — Backend Environment Variables
# Copy this file to .env and fill in your values.

# AI API Key — leave blank; users supply their own key via the app UI.
# The app supports: OpenRouter (sk-or-), OpenAI (sk-), Anthropic (sk-ant-), Gemini (AIza...), Groq (gsk_)
AI_API_KEY=

# SQLite database path (default is fine for local use)
DATABASE_URL=sqlite:///./dev_env_health.db

# JWT secret — change this to a random string in production
JWT_SECRET=devhealth_super_secret_key_change_in_production_2026
